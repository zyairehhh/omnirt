--- /dev/null
+++ b/flash_talk/src/quantization.py
@@ -0,0 +1,145 @@
+import json
+import os
+from fnmatch import fnmatch
+from pathlib import Path
+
+import torch
+import torch.nn as nn
+from safetensors.torch import save_file
+
+
+SUPPORTED_WEIGHT_QUANT = {"int8", "fp8"}
+
+DEFAULT_WAN_QUANT_INCLUDE = [
+    "blocks.*.self_attn.*",
+    "blocks.*.cross_attn.*",
+    "blocks.*.ffn.*",
+    "blocks.*.audio_cross_attn.*",
+    "audio_proj.*",
+]
+
+DEFAULT_WAN_QUANT_EXCLUDE = [
+    "blocks.*.self_attn.norm_*",
+    "blocks.*.cross_attn.norm_*",
+    "blocks.*.audio_cross_attn.*norm*",
+    "blocks.*.norm*",
+    "audio_proj.norm*",
+    "head.*",
+    "img_emb.*",
+]
+
+
+def _require_optimum_quanto():
+    os.environ.setdefault("TORCH_DEVICE_BACKEND_AUTOLOAD", "0")
+    try:
+        from optimum.quanto import freeze, qfloat8, qint8, quantization_map, quantize, requantize
+    except ModuleNotFoundError as exc:
+        raise RuntimeError(
+            "optimum-quanto is required for FlashTalk quantization flows. "
+            "Install it with `pip install optimum-quanto` or use requirements-ascend.txt."
+        ) from exc
+
+    return {
+        "freeze": freeze,
+        "qfloat8": qfloat8,
+        "qint8": qint8,
+        "quantization_map": quantization_map,
+        "quantize": quantize,
+        "requantize": requantize,
+    }
+
+
+def parse_pattern_list(value):
+    if value is None:
+        return None
+    if isinstance(value, str):
+        parts = [part.strip() for part in value.split(",")]
+        items = [part for part in parts if part]
+        return items or None
+    items = [str(part).strip() for part in value if str(part).strip()]
+    return items or None
+
+
+def resolve_weight_quant_name(quant):
+    if quant is None:
+        return None
+    quant = str(quant).strip().lower()
+    if quant not in SUPPORTED_WEIGHT_QUANT:
+        raise ValueError(
+            f"Unsupported quantization mode: {quant!r}. Expected one of {sorted(SUPPORTED_WEIGHT_QUANT)}."
+        )
+    return quant
+
+
+def resolve_weight_qtype(quant):
+    quanto = _require_optimum_quanto()
+    quant = resolve_weight_quant_name(quant)
+    if quant == "int8":
+        return quanto["qint8"]
+    if quant == "fp8":
+        return quanto["qfloat8"]
+    raise ValueError(f"Unsupported quantization mode: {quant!r}")
+
+
+def matches_patterns(name, include=None, exclude=None):
+    include = parse_pattern_list(include)
+    exclude = parse_pattern_list(exclude)
+
+    if include is not None and not any(fnmatch(name, pattern) for pattern in include):
+        return False
+    if exclude is not None and any(fnmatch(name, pattern) for pattern in exclude):
+        return False
+    return True
+
+
+def collect_quantizable_modules(model, include=None, exclude=None):
+    quantizable_types = (nn.Linear, nn.Conv2d, nn.LayerNorm)
+    matches = []
+    for name, module in model.named_modules():
+        if not name:
+            continue
+        if not isinstance(module, quantizable_types):
+            continue
+        if matches_patterns(name, include=include, exclude=exclude):
+            matches.append((name, module.__class__.__name__))
+    return matches
+
+
+def quantize_model_weights(model, quant, include=None, exclude=None):
+    quanto = _require_optimum_quanto()
+    qtype = resolve_weight_qtype(quant)
+    include = parse_pattern_list(include)
+    exclude = parse_pattern_list(exclude)
+    targets = collect_quantizable_modules(model, include=include, exclude=exclude)
+
+    quanto["quantize"](model, weights=qtype, include=include, exclude=exclude)
+    quanto["freeze"](model)
+    return targets
+
+
+def export_quantized_weights(model, quant, output_prefix):
+    quanto = _require_optimum_quanto()
+    output_prefix = Path(output_prefix)
+    output_prefix.parent.mkdir(parents=True, exist_ok=True)
+    save_file(model.state_dict(), str(output_prefix.with_suffix(".safetensors")))
+    with output_prefix.with_name(f"{output_prefix.name}_map.json").open("w", encoding="utf-8") as f:
+        json.dump(quanto["quantization_map"](model), f, indent=2, sort_keys=True)
+
+
+def export_quantized_model_files(model, quant, output_dir, stem):
+    quant = resolve_weight_quant_name(quant)
+    output_dir = Path(output_dir)
+    output_dir.mkdir(parents=True, exist_ok=True)
+
+    weights_path = output_dir / f"{stem}_{quant}.safetensors"
+    map_path = output_dir / f"{stem}_map_{quant}.json"
+    quanto = _require_optimum_quanto()
+    save_file(model.state_dict(), str(weights_path))
+    with map_path.open("w", encoding="utf-8") as f:
+        json.dump(quanto["quantization_map"](model), f, indent=2, sort_keys=True)
+    return weights_path, map_path
+
+
+def requantize_model(model, state_dict, quantization_map, device="cpu"):
+    quanto = _require_optimum_quanto()
+    quanto["requantize"](model, state_dict, quantization_map, device=device)
